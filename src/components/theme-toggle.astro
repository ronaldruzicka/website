---
import IconSun from '@icons/icon-sun.svg';
import IconMoon from '@icons/icon-moon.svg';
import { css, type Styles } from '@styles/css';
import { hstack, visuallyHidden } from '@styles/patterns';

const transitionProperty = 'rotate, translate, opacity';
const transitionTimingFunction = 'cubic-bezier(0.34, 1.56, 0.64, 1)';
---

<label
  class={hstack({
    position: 'relative',
    alignItems: 'center',
    width: '$14',
    height: '$8',
    py: '2px',
    px: '$1',
    backgroundColor: '{$colors.slate.800}',
    borderRadius: '$full',
    color: '$background',
    overflow: 'hidden',

    _after: {
      content: '""',
      position: 'absolute',
      top: '50%',
      left: '$0',
      width: '$6',
      height: '$6',
      borderRadius: '$full',
      backgroundColor: '{$colors.white}',
      translate: '{$spacing.1} -50%',
      transition: `translate {$durations.slower} ${transitionTimingFunction}`,

      _motionReduce: {
        transition: 'none',
      },
    },

    '&:has(input:checked)': {
      backgroundColor: 'oklch(from {$colors.yellow.500} 76% c 50)',

      _after: {
        translate: 'calc(100% + {$spacing.1}) -50%',
      },
    },
  })}
>
  <input class={visuallyHidden()} type="checkbox" name="theme-toggle" />

  <IconSun
    class={css({
      opacity: 0,
      rotate: '-180deg',
      translate: '50% 50%',
      transformOrigin: 'bottom right',
      transitionProperty,
      transitionDuration: '$slower',
      transitionTimingFunction,

      _motionReduce: {
        transition: 'none',
      },

      'input:checked~&': { rotate: '0deg', translate: '0% 0%', opacity: 1 },
    })}
  />

  <IconMoon
    class={css({
      color: '$neutral.300',
      opacity: 1,
      rotate: '0deg',
      translate: '0% 0%',
      transformOrigin: 'bottom left',
      transitionProperty,
      transitionDuration: '$slower',
      transitionTimingFunction,

      _motionReduce: {
        transition: 'none',
      },

      'input:checked~&': { rotate: '180deg', translate: '50% 50%', opacity: 0 },
    })}
  />
</label>

<script>
  const themeToggle = document.querySelector('input[name="theme-toggle"]') as HTMLInputElement;

  themeToggle.addEventListener('change', () => {
    document.documentElement.classList.toggle('dark');
  });
</script>
